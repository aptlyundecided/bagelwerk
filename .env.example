# Copy this file to `.env` and fill in local/provider-specific values.
# Do not commit `.env`.

# Built-in Flow runner defaults.
# FLOW_AGENT_RUNTIME selects the harness for agent-backed Nodes: cursor | opencode | claude-code | pi.
# FLOW_PROVIDER remains metadata/provider selection; when omitted, the CLI uses FLOW_AGENT_RUNTIME.
# Harness preflight: any Flow that composes core.agent-harness-check verifies the
# selected runtime's CLI is installed before running agent Nodes, and gates the run with install/
# login guidance if it isn't. It checks the same CLI paths configured below (e.g. CURSOR_AGENT_PATH,
# CLAUDE_CODE_PATH, OPENCODE_PATH). Auth is advisory only — it never blocks on login state.
FLOW_AGENT_RUNTIME=cursor
FLOW_PROVIDER=cursor
FLOW_MODEL=auto

# Required for agent-backed Nodes.
# Repo-relative by default — resolved against the directory you run commands from (the repo root).
# Set an absolute path instead if you prefer a fixed location. The directory must exist.
BAGELWERK_AGENT_ARTIFACTS_ROOT=.artifacts/agents

# Cursor Agent CLI. Set this when cursor-agent is not discoverable via PATH/default install location.
CURSOR_AGENT_PATH=C:/Users/<you>/AppData/Local/cursor-agent/agent.cmd

# Claude Code agent CLI. Set this when `claude` is not discoverable via PATH.
# CLAUDE_CODE_PATH=claude
# Claude Code runs headless (-p) and defaults to bypassPermissions so tool calls are not
# auto-denied; the -p mode also auto-skips the workspace trust dialog (no first-run prompt).
# Override the default mode here if you want stricter behavior (default | acceptEdits | plan | bypassPermissions).
# CLAUDE_CODE_PERMISSION_MODE=default

# OpenCode Agent CLI. Use this to give Cursor a break or compare harnesses.
# OpenCode expects FLOW_MODEL in provider/model form, for example openrouter/google/gemma-3-27b-it.
# OPENCODE_PATH=opencode
# FLOW_AGENT_RUNTIME=opencode
# FLOW_PROVIDER=opencode
# FLOW_MODEL=openrouter/google/gemma-3-27b-it
# FLOW_OPENCODE_AGENT=build
# FLOW_OPENCODE_SKIP_PERMISSIONS=1

# pi Agent CLI. pi is a spawned CLI like the others; set this if `pi` is not on PATH.
# pi manages its OWN providers, auth, and model config (e.g. a signed-in codex provider) —
# bagelwerk does not pass provider names or API keys to pi.
# PI_PATH=pi
# Model note: pi fuzzy-matches a model pattern across ALL its configured providers, so pin the
# provider to be explicit, and optionally append a thinking level (off|minimal|low|medium|high|xhigh):
#   FLOW_AGENT_RUNTIME=pi
#   FLOW_MODEL=openai-codex/gpt-5.4-mini:low

# Per-Flow/per-Node agent routing does not belong in .env.
# Use Flow executionPolicy or a Workbench run overlay for lane-specific harness/model choices.

# Optional API/model settings for tooling that calls OpenRouter.
# OPENROUTER_API_KEY=sk-or-v1-...
# OPENROUTER_MODEL=google/gemma-4-31b-it
