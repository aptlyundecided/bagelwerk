{
  "name": "bagelwerk",
  "version": "0.4.1",
  "private": true,
  "description": "Agent workflow engine for developers.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "keywords": [],
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "skills:sync": "tsx src/tools/skill-surface-parity/skillSurfaceParityCli.ts",
    "skills:sync:report": "npm run skills:sync -- --report-only",
    "open-items": "tsx .pi/skills/open-items/cli/openItemsCli.ts",
    "todos": "tsx .pi/skills/todo-contract/cli/todoContractCli.ts",
    "test": "npm run test:active",
    "test:active": "node scripts/active-surface-test-run/run.mjs default",
    "test:active:models": "node scripts/active-surface-test-run/run.mjs models",
    "sandcastle": "tsx .sandcastle/main.mts",
    "sandcastle:build-image": "sandcastle docker build-image --image-name sandcastle:bagelwerk",
    "sandcastle:remove-image": "sandcastle docker remove-image --image-name sandcastle:bagelwerk",
    "mermaid:render": "mmdc",
    "flow:runner": "tsx src/tools/flow-runner/flowRunnerCli.ts",
    "flow:supervisor": "tsx src/tools/flow-supervisor/flowSupervisorCli.ts",
    "flow:init": "tsx src/tools/flow-runner/flowInitCli.ts",
    "flow:tour": "tsx src/tools/built-ins/runPlatformTourFlowRunnerCli.ts",
    "flow:meal-plan": "tsx src/tools/flow-runner/flowRunnerCli.ts run-flow meal-plan-grocery:meal-plan-grocery --cwd flow-library/meal-plan-grocery --progress none",
    "flow:dinner-plan": "tsx src/tools/flow-runner/flowRunnerCli.ts run-flow dinner-plan-grocery:dinner-plan-grocery --cwd flow-library/dinner-plan-grocery --progress none",
    "flow:lunch-plan": "tsx src/tools/flow-runner/flowRunnerCli.ts run-flow lunch-plan-grocery:lunch-plan-grocery --cwd flow-library/lunch-plan-grocery --progress none",
    "flow:recipe-finder": "tsx src/tools/flow-runner/flowRunnerCli.ts run-flow recipe-finder:recipe-finder --cwd flow-library/recipe-finder --progress none",
    "cheerio-probe": "tsx src/tools/cheerio-probe/cheerioProbeCli.ts",
    "open-svg": "tsx .pi/skills/open-svg/cli/openSvg.ts"
  },
  "author": "",
  "license": "MPL-2.0",
  "dependencies": {
    "@electric-sql/pglite": "^0.4.6",
    "@inquirer/prompts": "^7.10.1",
    "@types/react": "^19.2.15",
    "chalk": "^4.1.2",
    "cheerio": "^1.2.0",
    "dotenv": "^17.4.2",
    "ink": "^7.0.4",
    "ink-select-input": "^6.2.0",
    "ink-text-input": "^6.0.0",
    "marked": "^15.0.12",
    "marked-terminal": "^7.3.0",
    "react": "^19.2.6",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@ai-hero/sandcastle": "^0.5.7",
    "@mermaid-js/mermaid-cli": "^11.12.0",
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
